# OpenRouter API - get key at openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Gemma 4 model identifiers on OpenRouter
GEMMA_MODEL_ACCURATE=google/gemma-4-31b-it:free
GEMMA_MODEL_FAST=google/gemma-4-26b-a4b-it:free

# Processing limits
MAX_FILE_SIZE_MB=50
JOB_TTL_HOURS=1
MAX_CONCURRENT_JOBS=5

# Backend
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
VERAPDF_PATH=/usr/local/bin/verapdf
TMP_DIR=/tmp/accessdoc

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAX_FILE_SIZE_MB=50
